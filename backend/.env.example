# SpeakBetter - Production Environment Template
# IMPORTANT: Do NOT commit this file with real keys to GitHub.
# In Render.com, add these keys in the "Environment" tab of your service.

# 1. Database Configuration
MONGODB_URL=your_mongodb_atlas_connection_string
DATABASE_NAME=speakbetter

# 2. Security
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your_super_secret_production_key

# 3. AI Engine (Gemini)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key

# 4. App Settings
PROJECT_NAME=SpeakBetter
ENVIRONMENT=production
